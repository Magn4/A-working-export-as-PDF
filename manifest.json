{
  "manifest_version": 3,
  "name": "H1 Report Exporter",
  "version": "0.3.0",
  "description": "Export HackerOne reports as pixel-perfect PDFs via screenshot.",
  "permissions": ["storage", "activeTab", "scripting", "debugger", "downloads"],
  "host_permissions": ["https://hackerone.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Export panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://hackerone.com/reports/*",
        "https://hackerone.com/bugs*"
      ],
      "js": ["defaults.js", "pdf-builder.js", "content.js"],
      "css": ["inject.css"],
      "run_at": "document_idle"
    }
  ]
}
